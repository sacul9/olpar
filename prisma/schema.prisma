generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── USUARIOS DEL SISTEMA ──────────────────────────────

model Usuario {
  id      String @id @default(cuid())
  authId  String @unique // Supabase Auth UUID
  nombre  String
  email   String @unique
  rol     Rol
  activo  Boolean  @default(true)
  creadoEn DateTime @default(now())

  sesiones    SesionDevolucion[]
  auditLogs   AuditLog[]
  notasCredito NotaCredito[] @relation("notaCreditoCreadaPor")

  @@map("usuarios")
}

enum Rol {
  dueno
  gerente
  bodeguero
  proveedor // P3: Portal proveedor read-only
}

// ─── CATALOGO DE PRODUCTOS ─────────────────────────────

model Producto {
  id              String   @id @default(cuid())
  codigoBarras    String   @unique
  nombre          String
  marca           String   // alpina | zenu | bimbo | otro
  categoria       String?
  unidad          String   // und | caja | kg | litro
  presentacion    String?  // "x6 900ml", "x12 150g"
  unidadesPorCaja Int      @default(1)
  refrigerado     Boolean  @default(false)
  skuAmovil       String?
  imagenUrl       String?  // URL de la imagen del producto
  // P1: Precios para KPIs financieros
  precioCosto     Float    @default(0)
  precioVenta     Float    @default(0)
  // P1: Politica de devolucion por producto
  diasMaxDevolucion Int    @default(7) // dias despues del vencimiento
  temperaturaMaxima Float? // P1: temp maxima aceptable en grados C (null = no aplica)
  pesoUnidad        Float? // P2: peso en kg por unidad (para validacion por peso)
  activo          Boolean  @default(true)
  creadoEn        DateTime @default(now())
  actualizadoEn   DateTime @updatedAt

  lineasDevolucion LineaDevolucion[]
  itemsDetectados  ItemDetectado[]
  inventario       Inventario?

  @@map("productos")
}

// ─── CONDUCTORES ───────────────────────────────────────

model Conductor {
  id       String  @id @default(cuid())
  cedula   String  @unique
  nombre   String
  placa    String?
  telefono String?
  ruta     String?
  email    String? // P1: para notificacion de discrepancias
  activo   Boolean @default(true)
  creadoEn DateTime @default(now())

  turnosCola ColaTurno[]
  sesiones   SesionDevolucion[]
  scores     ConductorScore[]

  @@map("conductores")
}

// ─── ESTACIONES DE DEVOLUCION (P3: multi-estacion) ─────

model Estacion {
  id        String  @id @default(cuid())
  nombre    String  // "Estacion 1", "Estacion Frio"
  tipo      String  @default("general") // general | refrigerado
  activa    Boolean @default(true)
  rpiApiKey String? // API key unica por estacion
  creadoEn  DateTime @default(now())

  sesiones SesionDevolucion[]

  @@map("estaciones")
}

// ─── COLA DE TURNOS (FIFO estricto) ────────────────────

model ColaTurno {
  id            String       @id @default(cuid())
  conductorId   String
  conductor     Conductor    @relation(fields: [conductorId], references: [id])
  numeroTurno   Int
  estado        EstadoTurno  @default(esperando)
  fechaRegistro DateTime     @default(now())
  fechaLlamado  DateTime?
  fechaFin      DateTime?

  sesion SesionDevolucion?

  @@index([estado, fechaRegistro])
  @@map("cola_turnos")
}

enum EstadoTurno {
  esperando
  en_atencion
  completado
  cancelado
}

// ─── SESIONES DE DEVOLUCION ────────────────────────────

model SesionDevolucion {
  id            String        @id @default(cuid())
  turnoId       String        @unique
  turno         ColaTurno     @relation(fields: [turnoId], references: [id])
  conductorId   String
  conductor     Conductor     @relation(fields: [conductorId], references: [id])
  bodegueroId   String
  bodeguero     Usuario       @relation(fields: [bodegueroId], references: [id])
  // P3: Multi-estacion
  estacionId    String?
  estacion      Estacion?     @relation(fields: [estacionId], references: [id])
  tienda        String
  // P2: Referencia a orden de despacho
  remisionId    String?       // ID de la remision/orden de despacho original
  remisionFecha DateTime?     // Fecha de la remision
  estado        EstadoSesion  @default(abierta)
  videoUrl      String?
  videoSubidoEn DateTime?
  camaraOffline Boolean       @default(false)
  notas         String?
  // P2: Firma digital
  firmaConductor   String?    // base64 de la firma del conductor
  firmaBodeguero   String?    // base64 de la firma del bodeguero
  firmaTimestamp   DateTime?  // cuando se firmaron
  // P1: Valor monetario total
  valorTotalDeclarado Float   @default(0)
  valorTotalDetectado Float   @default(0)
  creadoEn      DateTime      @default(now())
  cerradoEn     DateTime?

  lineas          LineaDevolucion[]
  itemsDetectados ItemDetectado[]
  alertas         Alerta[]
  notaCredito     NotaCredito?

  @@index([estado])
  @@index([conductorId])
  @@index([remisionId])
  @@map("sesiones_devolucion")
}

enum EstadoSesion {
  abierta
  cerrada
  rechazada  // P1: devolucion rechazada en dock
  cancelada
}

// ─── LINEAS DE DEVOLUCION (multi-producto por sesion) ──

model LineaDevolucion {
  id                String           @id @default(cuid())
  sesionId          String
  sesion            SesionDevolucion @relation(fields: [sesionId], references: [id])
  productoId        String
  producto          Producto         @relation(fields: [productoId], references: [id])
  motivo            MotivoDevolucion
  cantidadDeclarada Int
  cantidadDetectada Int              @default(0)
  estadoProducto    EstadoProducto   @default(sin_verificar)
  // P1: Temperatura al recibir
  temperaturaRegistrada Float?       // grados C medidos al recibir
  cadenaFrioOk          Boolean?     // null=no verificada, true=ok, false=rota
  // P1: Valor monetario por linea
  valorUnitario     Float            @default(0) // costo unitario al momento
  valorTotalLinea   Float            @default(0) // cantidadDetectada * valorUnitario
  // P1: Rechazo
  rechazada         Boolean          @default(false)
  motivoRechazo     String?          // motivo del rechazo
  notas             String?
  creadoEn          DateTime         @default(now())

  @@unique([sesionId, productoId, motivo])
  @@index([sesionId])
  @@map("lineas_devolucion")
}

enum MotivoDevolucion {
  vencido
  averiado
  cadena_frio
  fecha_corta
  sobrante
  producto_equivocado
  otro
}

enum EstadoProducto {
  sin_verificar
  bueno
  vencido
  daniado
  rechazado // P1: producto rechazado
}

// ─── ITEMS DETECTADOS POR LA CAMARA ────────────────────

model ItemDetectado {
  id              String           @id @default(cuid())
  sesionId        String
  sesion          SesionDevolucion @relation(fields: [sesionId], references: [id])
  productoId      String?
  producto        Producto?        @relation(fields: [productoId], references: [id])
  codigoBarras    String
  reconocido      Boolean          @default(false)
  idempotencyKey  String           @unique
  screenshotUrl   String?
  confianza       Float?
  detectadoEn     DateTime         @default(now())

  @@index([sesionId])
  @@index([codigoBarras])
  @@map("items_detectados")
}

// ─── NOTA CREDITO (P2) ─────────────────────────────────

model NotaCredito {
  id              String           @id @default(cuid())
  sesionId        String           @unique
  sesion          SesionDevolucion @relation(fields: [sesionId], references: [id])
  numero          String           @unique // NC-2026-0001
  tienda          String
  conductorNombre String
  // Detalle financiero
  subtotal        Float
  impuesto        Float            @default(0)
  total           Float
  estado          EstadoNotaCredito @default(borrador)
  // Detalle por linea (JSON snapshot)
  detalle         Json             // [{producto, cantidad, valorUnitario, subtotal}]
  // Metadata
  creadaPorId     String
  creadaPor       Usuario          @relation("notaCreditoCreadaPor", fields: [creadaPorId], references: [id])
  aprobadaEn      DateTime?
  creadoEn        DateTime         @default(now())

  @@index([estado])
  @@index([tienda])
  @@map("notas_credito")
}

enum EstadoNotaCredito {
  borrador
  aprobada
  enviada
  anulada
}

// ─── INVENTARIO ────────────────────────────────────────

model Inventario {
  id                  String    @id @default(cuid())
  productoId          String    @unique
  producto            Producto  @relation(fields: [productoId], references: [id])
  stockActual         Int       @default(0)
  ultimaActualizacion DateTime  @updatedAt

  movimientos MovimientoInventario[]

  @@map("inventario")
}

model MovimientoInventario {
  id           String     @id @default(cuid())
  inventarioId String
  inventario   Inventario @relation(fields: [inventarioId], references: [id])
  tipo         String     // entrada_devolucion | salida_despacho | ajuste
  cantidad     Int
  referencia   String?
  creadoEn     DateTime   @default(now())

  @@map("movimientos_inventario")
}

// ─── ALERTAS ───────────────────────────────────────────

model Alerta {
  id         String           @id @default(cuid())
  sesionId   String
  sesion     SesionDevolucion @relation(fields: [sesionId], references: [id])
  tipo       TipoAlerta
  mensaje    String
  enviada    Boolean          @default(false)
  enviadaEn  DateTime?
  resueltaEn DateTime?
  resueltaPor String?
  creadoEn   DateTime         @default(now())

  @@index([sesionId])
  @@map("alertas")
}

enum TipoAlerta {
  exceso_cantidad
  producto_incorrecto
  camara_offline
  sesion_sin_video
  conductor_flag
  cadena_frio_rota    // P1
  devolucion_rechazada // P1
  sla_espera          // P1: conductor esperando demasiado
}

// ─── SCORE DE CONDUCTORES ──────────────────────────────

model ConductorScore {
  id                     String    @id @default(cuid())
  conductorId            String
  conductor              Conductor @relation(fields: [conductorId], references: [id])
  semana                 String
  totalSesiones          Int
  sesionesConDiscrepancia Int
  porcentajeExactitud    Float     @default(100)
  valorEnRiesgo          Float     @default(0) // P1: valor monetario en discrepancia
  flagGenerado           Boolean   @default(false)
  creadoEn               DateTime  @default(now())

  @@unique([conductorId, semana])
  @@map("conductor_scores")
}

// ─── RATE LIMITING (P0) ────────────────────────────────

model RateLimit {
  id         String   @id @default(cuid())
  key        String   @unique // "scanner:{api_key}" or "ip:{ip}"
  tokens     Int      @default(60)
  lastRefill DateTime @default(now())

  @@map("rate_limits")
}

// ─── AUDIT LOG (append-only — NO UPDATE, NO DELETE) ────

model AuditLog {
  id            String   @id @default(cuid())
  usuarioId     String?
  usuario       Usuario? @relation(fields: [usuarioId], references: [id])
  accion        String
  entidad       String
  entidadId     String?
  detalle       Json?
  ip            String?
  creadoEn      DateTime @default(now())

  @@index([entidad, entidadId])
  @@index([creadoEn])
  @@map("audit_logs")
}
