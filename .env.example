# ─── Supabase ───────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ─── Database (Supabase PostgreSQL) ─────────────────────
# Pooled connection (PgBouncer) — for Prisma queries
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection — for Prisma migrations only
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# ─── Scanner RPi Authentication ─────────────────────────
# Generate with: openssl rand -hex 32
SCANNER_API_KEY="your-scanner-api-key"

# ─── Alertas (n8n webhooks) ─────────────────────────────
N8N_WEBHOOK_ALERTA="https://your-n8n.com/webhook/devoluciones-alerta"
N8N_WEBHOOK_CAMARA_OFFLINE="https://your-n8n.com/webhook/camara-offline"

# ─── Dueno (hardcoded — NUNCA configurable por otros roles)
OWNER_PHONE="+573001234567"
OWNER_EMAIL="dueno@distribuidora.com"

# ─── Cron Jobs (Vercel Cron) ────────────────────────────
CRON_SECRET="your-cron-secret"
