# Olpar Scanner — Environment Variables

# API connection
API_BASE_URL=https://tu-app.vercel.app
SCANNER_API_KEY=your-scanner-api-key

# Camera
CAMERA_INDEX=0
RESOLUTION_WIDTH=1280
RESOLUTION_HEIGHT=720
FPS=25

# Supabase Storage (for video upload)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
STORAGE_BUCKET=videos

# Optional overrides
# DEBOUNCE_SECONDS=3
# CAMERA_OFFLINE_SECONDS=5
# VIDEO_OUTPUT_DIR=/tmp/olpar_videos
# OFFLINE_DB_PATH=/tmp/olpar_offline.db
# LOCAL_API_PORT=8765
# MAX_RETRIES=3
